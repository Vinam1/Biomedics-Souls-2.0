rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role check helper
    function hasRole(roles) {
      return isSignedIn() && (
        request.auth.token.email == 'anderson2050eth@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'cliente') in roles
      );
    }

    function isAdmin() {
      return hasRole(['admin', 'superadmin']);
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && data.email.size() <= 200 &&
               (data.role == null || (data.role is string && data.role in ['admin', 'superadmin', 'cliente']));
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && 
                    isValidUser(incoming()) && 
                    (incoming().get('role', 'cliente') == 'cliente' || isAdmin());
      
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) && (
                      isAdmin() || (
                        // Clients cannot change their own role
                        incoming().get('role', 'cliente') == existing().get('role', 'cliente') &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastName', 'paternalLastName', 'maternalLastName', 'phoneNumber', 'updatedAt'])
                      )
                    );
    }

    // Products
    match /productos/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() <= 200 &&
               data.price is number && data.price >= 0;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Categories, Formats, Tags
    match /categorias/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /formatos/{formatId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /etiquetas/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /pedidos/{orderId} {
      allow read: if isOwner(resource.data.clientId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      
      allow create: if isSignedIn() && 
                    incoming().clientId == request.auth.uid &&
                    incoming().get('status', 'pending') == 'pending';
      
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews
    match /productos/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
